---
import Layout from '../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

const supabaseUrl = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;

const supabase = createClient(supabaseUrl, supabaseKey);

// Handle status updates, creations or deletions
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action') as string;

    if (action === 'add') {
      const name = data.get('name') as string;
      const url = data.get('url') as string;
      if (name && url) {
        await supabase.from('targets').insert({ name, url, is_active: true });
      }
    } else if (action === 'toggle') {
      const id = data.get('id') as string;
      const currentActive = data.get('current_active') === 'true';
      if (id) {
        await supabase
          .from('targets')
          .update({ is_active: !currentActive })
          .eq('id', id);
      }
    } else if (action === 'delete') {
      const id = data.get('id') as string;
      if (id) {
        await supabase.from('targets').delete().eq('id', id);
      }
    }
  } catch (e) {
    console.error('Error handling post action:', e);
  }
}

// Fetch active targets
const { data: targets } = await supabase
  .from('targets')
  .select('*')
  .order('created_at', { ascending: false });
---

<Layout title="Search Targets">
  <div class="targets-container">
    <!-- Form to add target -->
    <div class="glass-card add-target-card">
      <h2>Add ExpiredDomains.net Filter URL</h2>
      <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Configure your query on ExpiredDomains.net, click "Apply Filter", copy the browser address bar URL, and paste it below.</p>
      
      <form method="POST" class="target-form">
        <input type="hidden" name="action" value="add" />
        <div class="form-group">
          <label>Target Name</label>
          <input type="text" name="name" required placeholder="e.g. SEO Domain Target, Com Drops" class="glass-input-full" />
        </div>
        <div class="form-group">
          <label>ExpiredDomains.net URL</label>
          <input type="url" name="url" required placeholder="https://www.expireddomains.net/deleted-com-domains/?q=..." class="glass-input-full" />
        </div>
        <button type="submit" class="btn">Add Target</button>
      </form>
    </div>

    <!-- Configuration List -->
    <div class="glass-card targets-list">
      <h2>Configured Targets</h2>
      <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Managing lists targeted for periodic scraping.</p>

      <div class="targets-grid">
        {targets && targets.length > 0 ? (
          targets.map(t => (
            <div class="target-item glass-card">
              <div class="target-header">
                <h3>{t.name}</h3>
                <span class={`badge ${t.is_active ? 'badge-available' : 'badge-ignored'}`}>
                  {t.is_active ? 'Active' : 'Disabled'}
                </span>
              </div>
              <p class="target-url">{t.url}</p>
              
              <div class="target-controls-row">
                <span class="target-meta">Last Scraped: {t.last_scraped_at ? new Date(t.last_scraped_at).toLocaleDateString() : 'Never'}</span>
                
                <div class="target-actions">
                  <!-- Toggle Active Form -->
                  <form method="POST" style="display:inline;">
                    <input type="hidden" name="action" value="toggle" />
                    <input type="hidden" name="id" value={t.id} />
                    <input type="hidden" name="current_active" value={t.is_active ? 'true' : 'false'} />
                    <button type="submit" class="btn secondary-btn small-btn">
                      {t.is_active ? 'Disable' : 'Enable'}
                    </button>
                  </form>

                  <!-- Delete Target Form -->
                  <form method="POST" style="display:inline;">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={t.id} />
                    <button type="submit" class="btn delete-btn small-btn">
                      Delete
                    </button>
                  </form>
                </div>
              </div>
            </div>
          ))
        ) : (
          <p style="color: var(--text-muted); padding: 3rem; text-align: center;">No targets configured yet. Add a filter target above to start extracting.</p>
        )}
      </div>
    </div>
  </div>

  <style>
    .targets-container {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .target-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .targets-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .target-item {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: rgba(255, 255, 255, 0.01);
      border: 1px solid var(--glass-border);
    }
    .target-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .target-url {
      color: var(--text-muted);
      font-size: 0.85rem;
      word-break: break-all;
      font-family: monospace;
      background: rgba(0, 0, 0, 0.15);
      padding: 0.6rem 0.8rem;
      border-radius: 6px;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }
    .target-controls-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .target-meta {
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .target-actions {
      display: flex;
      gap: 0.5rem;
    }
    .small-btn {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
      border-radius: 6px;
      box-shadow: none;
    }
    .secondary-btn {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--glass-border);
      color: var(--text-main);
    }
    .secondary-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      transform: none;
    }
    .delete-btn {
      background: rgba(255, 71, 87, 0.1);
      border: 1px solid rgba(255, 71, 87, 0.3);
      color: var(--danger);
    }
    .delete-btn:hover {
      background: var(--danger);
      color: #000;
      transform: none;
      box-shadow: 0 4px 12px rgba(255, 71, 87, 0.2);
    }
  </style>
</Layout>
